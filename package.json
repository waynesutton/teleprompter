{
  "name": "teleprompt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "convex": "CONVEX_AGENT_MODE=anonymous convex dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npx @convex-dev/static-hosting deploy -c staticHosting",
    "deploy:static": "npx @convex-dev/static-hosting upload --build -c staticHosting --prod",
    "deploy:static:dev": "npx @convex-dev/static-hosting upload --build -c staticHosting --dev"
  },
  "dependencies": {
    "@convex-dev/static-hosting": "^0.1.3",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/inter-tight": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lexend": "^5.2.11",
    "@fontsource/opendyslexic": "^5.2.5",
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "^5.0.0",
    "convex": "^1.28.0",
    "convex-helpers": "^0.1.118",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.15.0"
  }
}
